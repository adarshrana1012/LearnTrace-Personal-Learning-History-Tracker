// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  email             String    @unique
  passwordHash      String    @map("password_hash")
  createdAt         DateTime  @default(now()) @map("created_at")
  emailVerified     Boolean   @default(false) @map("email_verified")
  verificationToken String?   @unique @map("verification_token")
  resetToken        String?   @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  refreshToken      String?   @map("refresh_token")
  publicProfileId   String?   @unique @map("public_profile_id")

  // role: "STUDENT" | "TEACHER" | "HOD" | "ADMIN" | "VAC_INCHARGE"
  // STUDENT       — one class, tracked by className
  // TEACHER       — manages one class (assigned via assignedClass), sees only that class
  // HOD           — Head of Department, sees all classes within their department
  // ADMIN         — legacy super-admin, sees all classes across college
  // VAC_INCHARGE  — reviews VAC course refund requests, no class visibility
  role          String   @default("STUDENT")
  gender        String?
  collegeName   String?  @map("college_name")
  department    String?
  className     String?  @map("class_name")
  rollNumber    String?  @map("roll_number")
  yearOfStudy   String?  @map("year_of_study")   // "First Year" | "Second Year" | etc.
  assignedClass String?  @map("assigned_class")  // For TEACHER: the ONE class they manage

  entries            LearningEntry[]
  vacRefundRequests  VacRefundRequest[]

  @@index([collegeName, className])
  @@index([role, collegeName])
  @@index([collegeName, department, role])
  @@map("users")
}

model LearningEntry {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  title           String
  platform        String
  domain          String
  subDomain       String?  @map("sub_domain")
  hoursSpent      Int?     @map("hours_spent")
  startDate       DateTime @map("start_date")
  completionDate  DateTime @map("completion_date")
  skills          String[] @default([])
  description     String?
  reflection      String?  @map("reflection")
  certificatePath String?  @map("certificate_path")
  status          String   @default("COMPLETED")
  difficulty      String?
  rating          Int?
  resourceUrl     String?  @map("resource_url")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completionDate(sort: Desc)])
  @@index([userId, domain])
  @@index([userId, platform])
  @@index([userId, createdAt(sort: Desc)])

  @@map("learning_entries")
}

model IdempotencyKey {
  key       String   @id
  entryId   String   @map("entry_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("idempotency_keys")
}

model VacRefundRequest {
  id                   String    @id @default(uuid())
  studentId            String    @map("student_id")

  // Document URLs — stored as Cloudinary URLs (or local paths as fallback)
  preApprovalPath      String?   @map("pre_approval_path")
  certificatePath      String?   @map("certificate_path")
  paymentReceiptPath   String?   @map("payment_receipt_path")
  additionalDocPath    String?   @map("additional_doc_path")

  // Submission metadata
  courseName           String    @map("course_name")
  platform             String
  courseAmount         Float     @map("course_amount")
  notes                String?

  // Workflow status
  status               String    @default("PENDING")   // "PENDING" | "APPROVED" | "REJECTED"
  rejectionReason      String?   @map("rejection_reason")
  reviewedBy           String?   @map("reviewed_by")
  reviewedAt           DateTime? @map("reviewed_at")

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  student              User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("vac_refund_requests")
}
